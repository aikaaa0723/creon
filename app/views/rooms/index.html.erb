<h2>メッセージルーム</h2>

<% if @rooms.any? %>
  <ul>
    <% @rooms.each do |room| %>
      <li>
        <% other_user = room.users.where.not(id: current_user.id).first %>
        <%= link_to other_user.username, room_path(room) %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>メッセージルームはありません。</p>
<% end %>
