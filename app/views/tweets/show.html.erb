<div class="min-h-screen bg-[#121212] text-white font-['Press_Start_2P'] p-6">

  <!-- 投稿詳細 -->
  <div class="bg-black/80 border-2 border-pink-400 rounded-2xl p-6 shadow-xl max-w-lg mx-auto">
    <h2 class="text-pink-400 text-xl mb-4">🖼 投稿詳細</h2>

    <% if @tweet.image.attached? %>
      <%= image_tag @tweet.image.variant(resize_to_limit: [300, 300]), class: "rounded-lg mx-auto mb-4" %>
    <% end %>

    <p class="text-sm mb-2"><%= @tweet.caption %></p>
    <p class="text-xs text-gray-400">by <%= @tweet.user.username || @tweet.user.email %></p>

    <% if user_signed_in? && current_user == @tweet.user %>
      <div class="mt-4 space-x-4">
        <%= link_to "✏ 編集", edit_tweet_path(@tweet), class: "text-blue-400 hover:underline" %>
        <%= link_to "🗑 削除", tweet_path(@tweet), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "text-red-400 hover:underline" %>
      </div>
    <% end %>
  </div>

  <!-- コメントセクション -->
  <div class="mt-10 max-w-2xl mx-auto">
    <h2 class="text-xl text-green-400 mb-4">💬 コメント</h2>

    <div id="comments" class="space-y-4">
      <% @tweet.comments.where(parent_id: nil).each do |comment| %>
        <%= render partial: "comments/comment", locals: { comment: comment } %>
      <% end %>
    </div>

    <div class="mt-6">
      <%= render 'comments/form', tweet: @tweet %>
    </div>
  </div>

  <!-- 閲覧時間のログ -->
  <script>
    const start = Date.now();
    window.addEventListener("beforeunload", function () {
      const duration = Math.floor((Date.now() - start) / 1000);
      fetch("<%= log_view_tweet_path(@tweet) %>", {
        method: "POST",
        headers: { "X-CSRF-Token": "<%= form_authenticity_token %>" },
        body: JSON.stringify({ duration: duration })
      });
    });
  </script>

  <!-- 戻る -->
  <div class="mt-8 text-center">
    <%= link_to "← 戻る", tweets_path, class: "text-yellow-400 hover:underline" %>
  </div>
</div>
